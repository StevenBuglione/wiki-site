{
  "schemaVersion": "steve-wiki-mcp-server-card/v1",
  "name": "AI Wiki",
  "description": "Repo-backed wiki for humans and AI agents.",
  "status": "planned",
  "transports": [],
  "resources": [
    "wiki://registry",
    "wiki://source/{sourceId}/manifest",
    "wiki://page/{sourceId}/{slug}",
    "wiki://section/{sourceId}/{slug}#{anchor}"
