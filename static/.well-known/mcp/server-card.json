  "tools": [
    "wiki.list_sources",
    "wiki.search",
    "wiki.get_page",
    "wiki.get_section",
    "wiki.filter_pages",
    "wiki.list_tags",
    "wiki.resolve_reference",
    "wiki.health"
  ],
  "webmcpDebugPage": "https://stevenbuglione.github.io/wiki-site/agents/"
}
