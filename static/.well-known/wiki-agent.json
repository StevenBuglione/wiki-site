{
  "schemaVersion": "steve-wiki-agent/v1",
  "name": "AI Wiki",
  "description": "Repo-backed wiki for humans and AI agents.",
  "humanHome": "https://stevenbuglione.github.io/wiki-site/",
  "llmsTxt": "https://stevenbuglione.github.io/wiki-site/llms.txt",
  "registryUrl": "https://cdn.jsdelivr.net/gh/StevenBuglione/wiki-data-registry@main/agent-sources.json",
  "webmcp": {
    "enabled": true,
    "tools": [
      "wiki.list_sources",
      "wiki.search",
      "wiki.get_page",
      "wiki.get_section",
      "wiki.filter_pages",
      "wiki.list_tags",
      "wiki.resolve_reference",
      "wiki.health"
    ],
    "debugPage": "https://stevenbuglione.github.io/wiki-site/agents/"
  },
  "mcp": { "enabled": false },
  "contentPolicy": { "public": true, "noSecrets": true, "aiGeneratedContentMarked": true, "citationsPreferred": true }
}
